# ─── Smart-Stua Simulator Configuration ──────────────────────────────────────
# Copy this file to .env and fill in your values.
# This file is read by simulator.py at startup.

# URL of your running Django backend API (no trailing slash on /api)
SIMULATOR_BASE_URL=http://127.0.0.1:8000/api

# Must match SENSOR_API_KEY in backend/.env exactly
SIMULATOR_API_KEY=dev-sensor-api-key

# Seconds between readings per node (default: 5)
SIMULATOR_INTERVAL_S=5

# Probability of injecting an anomaly each tick (0.0–1.0, default: 0.08 = 8%)
SIMULATOR_ANOMALY_RATE=0.08
