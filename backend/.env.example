# ═══════════════════════════════════════════════════════════════════════════════
# Smart-Stua Backend — Environment Variables Template
# Copy to .env and fill in real values before running docker compose.
# NEVER commit the real .env file to version control.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=replace-with-a-50-char-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-server-ip-or-domain

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Used by dj-database-url. Compose injects POSTGRES_HOST/PORT automatically.
DATABASE_URL=postgres://smartstua:your-db-password@db:5432/smartstua_db
POSTGRES_DB=smartstua_db
POSTGRES_USER=smartstua
POSTGRES_PASSWORD=your-strong-db-password-here

# ── Redis (Celery broker) ─────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── MQTT Broker ───────────────────────────────────────────────────────────────
MQTT_BROKER=mosquitto
MQTT_PORT=1883
# Leave blank to use anonymous (dev). Set for production auth:
MQTT_USERNAME=
MQTT_PASSWORD=

# ── Sensor Node Auth ──────────────────────────────────────────────────────────
# Global fallback key (used by HTTP endpoint). Per-node keys are stored in DB.
SENSOR_API_KEY=replace-with-32-char-secret

# ── CORS (allow Expo dev server and any deployed frontends) ───────────────────
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:3000

# ── First-Boot Admin Seed ─────────────────────────────────────────────────────
ADMIN_PHONE=+256700000000
ADMIN_EMAIL=admin@smartstua.local
ADMIN_DEFAULT_PASSWORD=SmartStua@Change-Me!

# ── Twilio SMS Alerts ─────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── Expose Ports (override defaults if needed) ────────────────────────────────
BACKEND_PORT=8000
MQTT_PORT=1883
