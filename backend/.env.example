# ═══════════════════════════════════════════════════════════════════════════════
# Smart-Stua Backend — Environment Variables Template
# Copy to .env and fill in real values before running docker compose.
# NEVER commit the real .env file to version control.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=replace-with-a-50-char-random-string
DEBUG=False
# Production: your Render subdomain. Add custom domain here once configured.
ALLOWED_HOSTS=localhost,127.0.0.1,smartstua-backend.onrender.com
CORS_ALLOWED_ORIGINS=https://smartstua-backend.onrender.com,http://localhost:8081

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL=postgres://smartstua:your-db-password@db:5432/smartstua_db
POSTGRES_DB=smartstua_db
POSTGRES_USER=smartstua
POSTGRES_PASSWORD=your-strong-db-password-here

# ── Redis (Celery broker) ─────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── MQTT Broker ───────────────────────────────────────────────────────────────
# LOCAL DOCKER: use mosquitto (container name)
MQTT_BROKER=mosquitto
MQTT_PORT=1883
# PRODUCTION (HiveMQ Cloud): replace with your HiveMQ Cloud cluster hostname
# MQTT_BROKER=<your-cluster>.s1.eu.hivemq.cloud
# MQTT_PORT=8883
MQTT_USERNAME=bridge
MQTT_PASSWORD=replace-with-strong-mqtt-password

# ── Sensor Node Auth ──────────────────────────────────────────────────────────
SENSOR_API_KEY=replace-with-32-char-secret

# ── First-Boot Admin Seed ─────────────────────────────────────────────────────
ADMIN_PHONE=+256762038491
ADMIN_EMAIL=raphaelocitti@gmail.com
ADMIN_DEFAULT_PASSWORD=SmartStua@Change-Me!

# ── Twilio SMS Alerts ─────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── Render.com Production ─────────────────────────────────────────────────────
# Render sets PORT automatically. WEB_CONCURRENCY controls Gunicorn workers.
PORT=8000
WEB_CONCURRENCY=2

# ── Expose Ports (local Docker only) ─────────────────────────────────────────
BACKEND_PORT=8000
